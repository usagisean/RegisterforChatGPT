# VPS deployment settings for docker-compose.deploy.yml
# Copy this file to .env on the VPS, then fill in the values you actually use.

# App and solver runtime
HOST=0.0.0.0
PORT=8000
APP_RELOAD=0
APP_CONDA_ENV=docker
APP_RUNTIME_DIR=/runtime
APP_ENABLE_SOLVER=1
SOLVER_PORT=8889
SOLVER_BIND_HOST=0.0.0.0
LOCAL_SOLVER_URL=http://127.0.0.1:8889
SOLVER_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=1
INSTALL_CAMOUFOX=0

# Persistent directories on the VPS
APP_RUNTIME_BIND=./data
APP_EXT_TARGETS_BIND=./_ext_targets
APP_EXTERNAL_LOGS_BIND=./external_logs

# Optional sidecar port bindings
CLIPROXYAPI_PORT_BIND=127.0.0.1:8317
GROK2API_PORT_BIND=127.0.0.1:8011

# Optional security and external service env vars
APP_JWT_SECRET=change-this-before-production
SMSTOME_COOKIE=
